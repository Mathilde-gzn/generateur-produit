{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/generate", "dest": "server.js" },
    { "src": "/me", "dest": "server.js" },
    { "src": "/webhook", "dest": "server.js" },
    { "src": "/signup", "dest": "server.js" },
    { "src": "/", "dest": "server.js" },
    { "src": "/(.*)", "dest": "server.js" }
  ],
  "functions": {
    "server.js": {
      "maxDuration": 60
    }
  }
}